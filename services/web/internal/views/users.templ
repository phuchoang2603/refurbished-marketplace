package views

templ UserPage(user UserView) {
	@AppShell("User", DefaultNav, UserDetailSection(user))
}

templ UserDetailSection(user UserView) {
	@Card(CardArgs{ID: "user-" + user.ID}) {
		@PageHeader(user.Email, "Account details")
		<p><strong>User ID:</strong> <code>{ user.ID }</code></p>
		@MetaLine(user.CreatedAt, user.UpdatedAt)
	}
}
